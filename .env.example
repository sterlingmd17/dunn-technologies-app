# Copy this file to `.env` for local development / deployment
DJANGO_SECRET_KEY=replace-me
DJANGO_DEBUG=True

# Contact form recipient
CONTACT_RECIPIENT_EMAIL=your_email@dunntech.com

# Email transport
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.yourprovider.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_HOST_USER=alerts@dunntech.com
EMAIL_HOST_PASSWORD=replace-with-app-password
EMAIL_TIMEOUT=15
DEFAULT_FROM_EMAIL="Dunn Technologies <alerts@dunntech.com>"
CONTACT_EMAIL_SUBJECT_PREFIX="[Website Lead]"